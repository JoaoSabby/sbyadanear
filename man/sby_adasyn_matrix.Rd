% Generated by sbyadanear maintenance notes
\name{sby_adasyn_matrix}
\alias{sby_adasyn_matrix}
\title{Aplicar ADASYN sobre matrix double densa}
\usage{
sby_adasyn_matrix(sby_x_matrix, sby_y_vector, sby_over_ratio = 0.2,
  sby_knn_over_k = 5L, sby_seed = sample.int(10L^5L, 1L),
  sby_audit = FALSE, sby_audit_level = c("none", "light", "full"),
  sby_return_scaled = FALSE, sby_return_original_scale = TRUE,
  sby_scaling_info = NULL, sby_input_already_scaled = FALSE,
  sby_knn_algorithm = c("auto", "kd_tree", "cover_tree", "brute"),
  sby_knn_engine = c("auto", "native", "FNN", "RcppHNSW", "KernelKnn", "bigKNN"),
  sby_knn_distance_metric = c("euclidean", "ip", "cosine"),
  sby_knn_workers = 1L, sby_knn_parallel_backend = c("parallel", "RcppParallel"), sby_knn_hnsw_m = 16L,
  sby_knn_hnsw_ef = 200L, sby_knn_query_chunk_size = 1000L, sby_memory_guard = TRUE,
  sby_max_output_rows = Inf, sby_max_dense_gb = Inf)
}
\arguments{
\item{sby_x_matrix}{Matrix double densa de preditores. Matrizes esparsas não são aceitas.}
\item{sby_y_vector}{Fator binário alinhado às linhas de \code{sby_x_matrix}.}
\item{sby_over_ratio}{Multiplicador relativo da classe minoritária para gerar linhas sintéticas; não é a razão final minoria/maioria.}
\item{sby_knn_over_k}{Número de vizinhos usados na dificuldade local do ADASYN.}
\item{sby_seed}{Semente reprodutível.}
\item{sby_audit, sby_audit_level}{Controle de auditoria: \code{none}, \code{light} ou \code{full}.}
\item{sby_return_scaled}{Se \code{TRUE}, retorna matriz balanceada em z-score e parâmetros de escala.}
\item{sby_return_original_scale}{Se \code{TRUE}, retorna \code{sby_x_matrix} na escala original.}
\item{sby_scaling_info, sby_input_already_scaled}{Parâmetros para reutilizar escala pré-computada.}
\item{sby_knn_algorithm, sby_knn_engine, sby_knn_distance_metric, sby_knn_workers, sby_knn_parallel_backend, sby_knn_hnsw_m, sby_knn_hnsw_ef, sby_knn_query_chunk_size}{Configuração do KNN exato ou aproximado.}
\item{sby_memory_guard, sby_max_output_rows, sby_max_dense_gb}{Controles de segurança para alocação densa.}
}
\description{Gera observações sintéticas da classe minoritária por ADASYN usando matriz double densa e busca KNN configurável.}
\details{Quando \code{sby_knn_parallel_backend = "RcppParallel"}, o runtime concreto pode ser TBB/oneTBB ou TinyThread conforme a instalação de \pkg{RcppParallel}; os diagnósticos auditáveis incluem \code{sby_knn_parallel_runtime}. A função padroniza os preditores por z-score antes do KNN, gera sintéticos no espaço padronizado e opcionalmente reverte para escala original. Use \code{sby_return_scaled = TRUE} para encadear com outras rotinas matriciais sem auditoria completa.}
\value{Lista com \code{sby_x_matrix}, \code{sby_y_vector}, razões e distribuições de classe e \code{sby_diagnostics}; pode incluir \code{sby_scaling_info} e \code{sby_balanced_scaled}.}
\examples{
x <- matrix(rnorm(40), ncol = 2); storage.mode(x) <- "double"
y <- factor(c(rep("minor", 5), rep("major", 15)))
sby_adasyn_matrix(x, y, sby_seed = 1, sby_knn_engine = "FNN")
}
\seealso{\code{\link{sby_nearmiss_matrix}}, \code{\link{sby_adanear_matrix}}, \code{\link{sby_balance_matrix}}}
\references{He, H. et al. (2008). ADASYN: Adaptive synthetic sampling approach for imbalanced learning.}
