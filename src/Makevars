CXX_STD = CXX23
OBJECTS = sbyadanear.o sbyadanear_rcppparallel.o sby_native_engine.o sby_hpc_engine.o sby_hpc_engine_f.o

PKG_CPPFLAGS += -DSBYADANEAR_ONEAPI_MKL_OPTIONAL=1
PKG_CPPFLAGS += -DSBYADANEAR_ONEAPI_MKL=1
PKG_CPPFLAGS += -DSBYADANEAR_CASCADELAKE_NATIVE=1
PKG_CPPFLAGS += -DSBY_ASSUME_NO_NA=1
PKG_CPPFLAGS += -DSBY_PREFERRED_FEATURES=100

PKG_CPPFLAGS += $(shell "$(R_HOME)/bin$(R_ARCH_BIN)/Rscript" -e "suppressPackageStartupMessages(library(RcppParallel)); cat(RcppParallel::CxxFlags())")
PKG_LIBS += $(shell "$(R_HOME)/bin$(R_ARCH_BIN)/Rscript" -e "suppressPackageStartupMessages(library(RcppParallel)); cat(RcppParallel::RcppParallelLibs())")
